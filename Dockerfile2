# Use a slim Python image
FROM python:3.12-slim-bullseye

# Avoid Python buffering
ENV PYTHONUNBUFFERED=1

# Create code directory
WORKDIR /code

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements.txt \
    && rm -rf /root/.cache/

# Copy project
COPY . /code/

# Collect static files (optional at build time)
RUN python manage.py collectstatic --noinput

# Persistent process: Gunicorn
# Replace 'ex_libris_2.wsgi:application' with your actual WSGI module if different
CMD ["gunicorn", "ex_libris_2.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "2"]